    {
      "cell_type": "markdown",
      "metadata": {
        "id": "step-4-1-advanced"
      },
      "source": [
        "## 🎨 Step 4.1: Advanced Visual Mode (Interactive Cropping) (Recommended)\n",
        "Interactive UI using Gradio Image Editor for precise subtitle area selection. \n",
        "Features: **Visual Video Seeker**, **Persistent Mode**, **Video Upload**, and **Real-time ETA/Speed tracking**."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "run-gradio-advanced"
      },
      "outputs": [],
      "source": [
        "import gradio as gr\n",
        "import cv2\n",
        "import numpy as np\n",
        "import headless\n",
        "import os\n",
        "import config as C\n",
        "import shutil\n",
        "import time\n",
        "from pathlib import Path\n",
        "import subprocess\n",
        "\n",
        "def format_time(seconds):\n",
        "    if seconds <= 0: return \"00:00\"\n",
        "    m, s = divmod(int(seconds), 60)\n",
        "    h, m = divmod(m, 60)\n",
        "    if h > 0: return f\"{h:d}:{m:02d}:{s:02d}\"\n",
        "    return f\"{m:02d}:{s:02d}\"\n",
        "\n",
        "def get_sample_frame(video_path, timestamp=5):\n",
        "    if not video_path or not os.path.exists(video_path):\n",
        "        return None\n",
        "    sample_frame_path = \"/tmp/sample_frame.jpg\"\n",
        "    time_str = str(timestamp)\n",
        "    try:\n",
        "        subprocess.run([\n",
        "            \"ffmpeg\", \"-y\", \"-ss\", time_str, \"-i\", video_path, \n",
        "            \"-vframes\", \"1\", \"-q:v\", \"2\", sample_frame_path\n",
        "        ], check=True, capture_output=True)\n",
        "    except:\n",
        "        subprocess.run([\n",
        "            \"ffmpeg\", \"-y\", \"-i\", video_path, \"-ss\", time_str,\n",
        "            \"-vframes\", \"1\", \"-q:v\", \"2\", sample_frame_path\n",
        "        ], check=True, capture_output=True)\n",
        "    return sample_frame_path\n",
        "\n",
        "def update_video_info(path):\n",
        "    if not path or not os.path.exists(path):\n",
        "        return gr.update(maximum=100, value=0), \"Duration: 00:00\"\n",
        "    dur = headless.get_video_duration(path)\n",
        "    return gr.update(maximum=dur, value=min(5, dur)), f\"Duration: {format_time(dur)}\"\n",
        "\n",
        "def seek_relative(current_ts, delta, video_path):\n",
        "    dur = headless.get_video_duration(video_path)\n",
        "    new_ts = max(0, min(current_ts + delta, dur))\n",
        "    return new_ts\n",
        "\n",
        "def handle_upload(file):\n",
        "    if file is None: \n",
        "        return \"\", \"❌ No file selected.\"\n",
        "    filename = os.path.basename(file.name)\n",
        "    dest = os.path.join(\"/content\", filename)\n",
        "    yield \"\", f\"⏳ Processing upload: {filename}...\"\n",
        "    try:\n",
        "        shutil.copy(file.name, dest)\n",
        "        yield dest, f\"✅ Upload successful! File saved to: {dest}\"\n",
        "    except Exception as e:\n",
        "        yield \"\", f\"❌ Error saving uploaded file: {str(e)}\"\n",
        "\n",
        "def save_to_drive(srt_path, drive_folder):\n",
        "    if not srt_path or not os.path.exists(srt_path):\n",
        "        return \"❌ SRT file not found. Please run extraction first.\"\n",
        "    try:\n",
        "        if not os.path.exists(drive_folder):\n",
        "            os.makedirs(drive_folder, exist_ok=True)\n",
        "        dest = os.path.join(drive_folder, os.path.basename(srt_path))\n",
        "        shutil.copy(srt_path, dest)\n",
        "        return f\"✅ Saved to: {dest}\"\n",
        "    except Exception as e:\n",
        "        return f\"❌ Error saving to Drive: {str(e)}\"\n",
        "\n",
        "def start_extraction_advanced(video_path, image_editor, persistent_mode, progress=gr.Progress()):\n",
        "    if not video_path or not os.path.exists(video_path):\n",
        "        yield \"❌ Invalid video path.\", None\n",
        "        return\n",
        "    if image_editor is None or \"composite\" not in image_editor:\n",
        "        yield \"❌ Please seek to a frame and crop the subtitle area.\", None\n",
        "        return\n",
        "\n",
        "    try:\n",
        "        yield \"⏳ Analyzing original sample frame...\", None\n",
        "        orig_frame_path = \"/tmp/sample_frame.jpg\"\n",
        "        if not os.path.exists(orig_frame_path):\n",
        "            yield \"❌ Original sample frame not found. Please try again.\", None\n",
        "            return\n",
        "            \n",
        "        orig_img = cv2.imread(orig_frame_path)\n",
        "        orig_h, orig_w, _ = orig_img.shape\n",
        "        cropped_img = image_editor[\"composite\"] \n",
        "        h, w, c = cropped_img.shape\n",
        "        x_min, y_min, x_max, y_max = 0, 0, w, h\n",
        "        is_cropped = False\n",
        "        if h < orig_h or w < orig_w:\n",
        "            is_cropped = True\n",
        "            if c == 4: cropped_bgr = cv2.cvtColor(cropped_img, cv2.COLOR_RGBA2BGR)\n",
        "            else: cropped_bgr = cropped_img\n",
        "            res = cv2.matchTemplate(orig_img, cropped_bgr, cv2.TM_CCOEFF_NORMED)\n",
        "            _, _, _, max_loc = cv2.minMaxLoc(res)\n",
        "            x_min, y_min = max_loc\n",
        "            x_max, y_max = x_min + w, y_min + h\n",
        "        elif c == 4:\n",
        "            alpha = cropped_img[:, :, 3]\n",
        "            if np.any(alpha < 250):\n",
        "                non_transparent = alpha > 10\n",
        "                if np.any(non_transparent):\n",
        "                    rows, cols = np.any(non_transparent, axis=1), np.any(non_transparent, axis=0)\n",
        "                    y_indices, x_indices = np.where(rows)[0], np.where(cols)[0]\n",
        "                    if len(y_indices) > 0 and len(x_indices) > 0:\n",
        "                        y_min, y_max = y_indices[0], y_indices[-1]\n",
        "                        x_min, x_max = x_indices[0], x_indices[-1]\n",
        "                        if (x_max - x_min < orig_w - 5) or (y_max - y_min < orig_h - 5): is_cropped = True\n",
        "        \n",
        "        if not is_cropped:\n",
        "            yield \"⚠️ You haven't cropped yet. Please use the crop tool on the image editor.\", None\n",
        "            return\n",
        "\n",
        "        top_crop, bottom_crop = (orig_h - y_min) / orig_h, (orig_h - y_max) / orig_h\n",
        "        left_crop, right_crop = x_min / orig_w, x_max / orig_w\n",
        "\n",
        "        video_name = Path(video_path).stem\n",
        "        output_dir = os.path.join(\"/content/drive/MyDrive/AutoVSF/temp_outputs\", video_name) if persistent_mode else os.path.join(\"/content\", f\"{video_name}_out\")\n",
        "        \n",
        "        C.state.reset()\n",
        "        def run_task():\n",
        "            try:\n",
        "                y_min_vsf, y_max_vsf = min(top_crop, bottom_crop), max(top_crop, bottom_crop)\n",
        "                if y_min_vsf == y_max_vsf: y_max_vsf += 0.05\n",
        "                headless.run_headless(video_path, y_max_vsf, y_min_vsf, left_crop, right_crop, \n",
        "                                     output_dir=output_dir, skip_if_exists=persistent_mode)\n",
        "            except Exception as e: print(f\"Error in headless thread: {e}\")\n",
        "\n",
        "        import threading\n",
        "        t = threading.Thread(target=run_task, daemon=True)\n",
        "        t.start()\n",
        "\n",
        "        progress(0, desc=\"🚀 Initializing...\")\n",
        "        while t.is_alive():\n",
        "            elapsed = time.time() - C.state.t0 if C.state.t0 else 0\n",
        "            if C.state.total > 0:\n",
        "                ocr_prog = C.state.done / C.state.total\n",
        "                prog = 0.85 + (ocr_prog * 0.15)\n",
        "                speed = C.state.done / elapsed if elapsed > 0 else 0\n",
        "                eta = (C.state.total - C.state.done) / speed if speed > 0 else 0\n",
        "                desc_str = f\"⚡ Phase 2/2: OCR... {C.state.done}/{C.state.total} | Speed: {speed:.1f} f/s | ETA: {format_time(eta)}\"\n",
        "                progress(prog, desc=desc_str)\n",
        "                yield f\"⚙️ {desc_str}\", None\n",
        "            else:\n",
        "                scan_prog = C.state.scan_progress\n",
        "                prog_val = (scan_prog / 100) * 0.85\n",
        "                duration_str = format_time(C.state.video_duration)\n",
        "                eta = (100 - scan_prog) * (elapsed / scan_prog) if scan_prog > 0 and elapsed > 0 else 0\n",
        "                desc_str = f\"🎞️ Phase 1/2: Scanning... {scan_prog:.0f}% | Duration: {duration_str} | ETA: {format_time(eta)}\"\n",
        "                progress(prog_val, desc=desc_str)\n",
        "                yield f\"⏳ {desc_str}\", None\n",
        "            time.sleep(1.5)\n",
        "\n",
        "        srt_out = str(Path(video_path).with_suffix('.srt'))\n",
        "        if os.path.exists(srt_out): yield f\"✅ Extraction successful! File: {srt_out}\", srt_out\n",
        "        else: yield \"⚠️ Finished. Check logs if .srt file is missing.\", None\n",
        "    except Exception as e: yield f\"❌ Error: {str(e)}\", None\n",
        "\n",
        "with gr.Blocks(title=\"AutoVSF Advanced\") as demo:\n",
        "    gr.Markdown(\"# 🎨 AutoVSF Advanced Visual Mode (Recommended)\")\n",
        "    with gr.Row():\n",
        "        with gr.Column(scale=2):\n",
        "            video_in = gr.Textbox(label=\"Video Path\", value=\"/content/video_test.mp4\")\n",
        "            with gr.Row():\n",
        "                upload_btn = gr.UploadButton(\"📁 Upload Video\", file_types=[\"video\"])\n",
        "                dur_info = gr.Markdown(\"Duration: 00:00\")\n",
        "            seek_slider = gr.Slider(label=\"Seek Frame (Seconds)\", minimum=0, maximum=100, step=1, value=5)\n",
        "            with gr.Row():\n",
        "                btn_m30 = gr.Button(\"-30s\")\n",
        "                btn_m5 = gr.Button(\"-5s\")\n",
        "                btn_p5 = gr.Button(\"+5s\")\n",
        "                btn_p30 = gr.Button(\"+30s\")\n",
        "            btn_frame = gr.Button(\"📷 Refresh Frame Preview\", variant=\"secondary\")\n",
        "        with gr.Column(scale=3):\n",
        "            img_editor = gr.ImageEditor(label=\"Crop Area\", type=\"numpy\", crop_size=None, transforms=[\"crop\"], brush=False, eraser=False)\n",
        "    with gr.Row():\n",
        "        persistent_chk = gr.Checkbox(label=\"Persistent Mode (Save frames to Drive)\", value=False)\n",
        "        btn_start = gr.Button(\"🚀 Start Extraction\", variant=\"primary\")\n",
        "    st_out = gr.Textbox(label=\"System Status\")\n",
        "    srt_file = gr.File(label=\"Download SRT Result\", interactive=False)\n",
        "    with gr.Accordion(\"Google Drive Options\", open=False):\n",
        "        drive_path = gr.Textbox(label=\"Drive Folder Path\", value=\"/content/drive/MyDrive/AutoVSF/Results\")\n",
        "        btn_drive = gr.Button(\"💾 Save SRT to Drive\")\n",
        "        drive_status = gr.Markdown()\n",
        "    video_in.change(update_video_info, video_in, [seek_slider, dur_info])\n",
        "    upload_btn.upload(handle_upload, upload_btn, [video_in, st_out])\n",
        "    seek_slider.release(get_sample_frame, [video_in, seek_slider], img_editor)\n",
        "    btn_frame.click(get_sample_frame, [video_in, seek_slider], img_editor)\n",
        "    btn_m30.click(seek_relative, [seek_slider, gr.State(-30), video_in], seek_slider)\n",
        "    btn_m5.click(seek_relative, [seek_slider, gr.State(-5), video_in], seek_slider)\n",
        "    btn_p5.click(seek_relative, [seek_slider, gr.State(5), video_in], seek_slider)\n",
        "    btn_p30.click(seek_relative, [seek_slider, gr.State(30), video_in], seek_slider)\n",
        "    seek_slider.change(get_sample_frame, [video_in, seek_slider], img_editor)\n",
        "    btn_start.click(start_extraction_advanced, [video_in, img_editor, persistent_chk], [st_out, srt_file])\n",
        "    btn_drive.click(save_to_drive, [srt_file, drive_path], drive_status)\n",
        "demo.queue().launch(share=True)\n"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "step-4-2-cli"
      },
      "source": [
        "## 🚀 Step 4.2: CLI Mode (Fast Execution - Auto 30%)\n",
        "Quickly run extraction using relative coordinates. Ideal for batches or known subtitle positions."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "execution"
      },
      "outputs": [],
      "source": [
        "# @title 🚀 Step 4.2: CLI Mode (Fast Execution - Auto 30%)\n",
        "import os\n",
        "from pathlib import Path\n",
        "\n",
        "# @markdown ### 💡 Settings:\n",
        "VIDEO_PATH = \"/content/video_test.mp4\" # @param {type:\"string\"}\n",
        "PERSISTENT_MODE = False # @param {type:\"boolean\"}\n",
        "\n",
        "# @markdown ### ✂️ Crop Region Selection Guide (0.0 - 1.0):\n",
        "TOP_CROP = 0.3 # @param {type:\"number\"}\n",
        "BOTTOM_CROP = 0.0 # @param {type:\"number\"}\n",
        "LEFT_CROP = 0.0 # @param {type:\"number\"}\n",
        "RIGHT_CROP = 1.0 # @param {type:\"number\"}\n",
        "\n",
        "OUTPUT_ARG = \"\"\n",
        "SKIP_ARG = \"\"\n",
        "if PERSISTENT_MODE:\n",
        "    video_name = Path(VIDEO_PATH).stem\n",
        "    drive_out = os.path.join(\"/content/drive/MyDrive/AutoVSF/temp_outputs\", video_name)\n",
        "    OUTPUT_ARG = f\"--output '{drive_out}'\"\n",
        "    SKIP_ARG = \"--skip\"\n",
        "    print(f\"📂 Persistent Mode ON: Frames saved to {drive_out}\")\n",
        "\n",
        "!python3 headless.py \"$VIDEO_PATH\" --top $TOP_CROP --bottom $BOTTOM_CROP --left $LEFT_CROP --right $RIGHT_CROP $OUTPUT_ARG $SKIP_ARG"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "step-4-3-basic"
      },
      "source": [
        "## 🎨 Step 4.3: Basic Visual Mode (Slider Selection)\n",
        "Simple interface using sliders to define the extraction boundaries."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "run-gradio"
      },
      "outputs": [],
      "source": [
        "# @title 🎨 Step 4.3: Basic Visual Mode (Slider Selection)\n",
        "try:\n",
        "    import gradio as gr\n",
        "except:\n",
        "    !pip install -q gradio\n",
        "    import gradio as gr\n",
        "\n",
        "import os, threading, time\n",
        "from pathlib import Path\n",
        "import config as C\n",
        "import headless\n",
        "\n",
        "def format_time(seconds):\n",
        "    if seconds <= 0: return \"00:00\"\n",
        "    m, s = divmod(int(seconds), 60)\n",
        "    h, m = divmod(m, 60)\n",
        "    return f\"{h:d}:{m:02d}:{s:02d}\" if h > 0 else f\"{m:02d}:{s:02d}\"\n",
        "\n",
        "def load_last_settings():\n",
        "    cfg = C.load()\n",
        "    profile = cfg.get(\"crop_profiles\", {}).get(\"colab_last_run\", {})\n",
        "    return (profile.get(\"top\", 0.3), profile.get(\"bottom\", 0.0), profile.get(\"left\", 0.0), profile.get(\"right\", 1.0))\n",
        "\n",
        "def save_settings(top, bottom, left, right):\n",
        "    cfg = C.load()\n",
        "    if \"crop_profiles\" not in cfg: cfg[\"crop_profiles\"] = {}\n",
        "    cfg[\"crop_profiles\"][\"colab_last_run\"] = {\"top\": top, \"bottom\": bottom, \"left\": left, \"right\": right}\n",
        "    C.save(cfg)\n",
        "    return \"✅ Profile saved to settings.json\"\n",
        "\n",
        "def start_extraction(video_path, top, bottom, left, right, progress=gr.Progress()):\n",
        "    if not video_path or not os.path.exists(video_path): return \"❌ Video path invalid.\"\n",
        "    save_settings(top, bottom, left, right)\n",
        "    C.state.reset()\n",
        "    def run_task():\n",
        "        try: headless.run_headless(video_path, max(top, bottom), min(top, bottom), left, right)\n",
        "        except Exception as e: print(f\"Error: {e}\")\n",
        "    threading.Thread(target=run_task, daemon=True).start()\n",
        "    progress(0, desc=\"🚀 Initializing...\")\n",
        "    while True:\n",
        "        elapsed = time.time() - C.state.t0 if C.state.t0 else 0\n",
        "        if C.state.total > 0:\n",
        "            prog = C.state.done / C.state.total\n",
        "            speed = C.state.done / elapsed if elapsed > 0 else 0\n",
        "            eta = (C.state.total - C.state.done) / speed if speed > 0 else 0\n",
        "            progress(prog, desc=f\"⏳ OCR: {C.state.done}/{C.state.total} | Speed: {speed:.1f} f/s | ETA: {format_time(eta)}\")\n",
        "        else:\n",
        "            scan_prog = C.state.scan_progress\n",
        "            eta = (100 - scan_prog) * (elapsed / scan_prog) if scan_prog > 0 else 0\n",
        "            progress(scan_prog/100, desc=f\"🎞️ Scanning: {scan_prog:.0f}% | ETA: {format_time(eta)}\")\n",
        "        if C.state.done >= C.state.total and C.state.total > 0: break\n",
        "        time.sleep(1)\n",
        "    return f\"✅ Done! Output: {Path(video_path).with_suffix('.srt')}\"\n",
        "\n",
        "def get_status_text():\n",
        "    elapsed = time.time() - C.state.t0 if C.state.t0 else 0\n",
        "    if C.state.total == 0:\n",
        "        scan_prog = C.state.scan_progress\n",
        "        return f\"### Status: Scanning {scan_prog:.0f}% | ETA: {format_time((100-scan_prog)*(elapsed/scan_prog) if scan_prog>0 else 0)}\"\n",
        "    prog = C.state.done / C.state.total\n",
        "    speed = C.state.done / elapsed if elapsed > 0 else 0\n",
        "    eta = (C.state.total - C.state.done) / speed if speed > 0 else 0\n",
        "    return f\"### Progress: {C.state.done}/{C.state.total} ({prog*100:.1f}%) | Speed: {speed:.1f} f/s | ETA: {format_time(eta)}\"\n",
        "\n",
        "with gr.Blocks(title=\"AutoVSF Basic\") as demo:\n",
        "    gr.Markdown(\"# 🎬 AutoVSF Basic Interface\")\n",
        "    with gr.Row():\n",
        "        with gr.Column(scale=2):\n",
        "            video_in = gr.Textbox(label=\"Video Path\", value=\"/content/video_test.mp4\")\n",
        "            with gr.Group():\n",
        "                with gr.Row():\n",
        "                    t_sld = gr.Slider(0, 1, value=0.3, step=0.01, label=\"Top\")\n",
        "                    b_sld = gr.Slider(0, 1, value=0.0, step=0.01, label=\"Bottom\")\n",
        "                with gr.Row():\n",
        "                    l_sld = gr.Slider(0, 1, value=0.0, step=0.01, label=\"Left\")\n",
        "                    r_sld = gr.Slider(0, 1, value=1.0, step=0.01, label=\"Right\")\n",
        "            with gr.Row():\n",
        "                btn_save = gr.Button(\"💾 Save Profile\")\n",
        "                btn_start = gr.Button(\"🚀 Start Extraction\", variant=\"primary\")\n",
        "        with gr.Column(scale=1):\n",
        "            prog_txt = gr.Markdown(\"### Status: Ready\")\n",
        "            demo.load(load_last_settings, None, [t_sld, b_sld, l_sld, r_sld])\n",
        "            if hasattr(gr, \"Timer\"): gr.Timer(2).tick(get_status_text, None, prog_txt)\n",
        "    btn_save.click(save_settings, [t_sld, b_sld, l_sld, r_sld])\n",
        "    btn_start.click(start_extraction, [video_in, t_sld, b_sld, l_sld, r_sld])\n",
        "demo.queue().launch(share=True, height=600)\n"
      ]
